# UncookedAura – Cloudflare integration (test/example)
# Copy to .env and fill in values. Do not commit .env.

# ---------------------------------------------------------------------------
# Cloudflare Workers API (job search / R2-backed data)
# Your Worker URL when deployed, e.g. https://uncookedaura-api.<account>.workers.dev
# Leave empty to use mock data in the UI.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CF_WORKERS_API_URL=

# ---------------------------------------------------------------------------
# Cloudflare Pages (optional)
# Canonical app URL when deployed on Pages, e.g. https://uncookedaura.pages.dev
# Used for absolute URLs and analytics.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CF_PAGES_URL=

# ---------------------------------------------------------------------------
# Optional: Public API key for Worker endpoints that require auth
# (e.g. rate limiting or partner APIs). Not for R2 credentials (R2 is Worker-only).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CF_API_KEY=

# ---------------------------------------------------------------------------
# Jooble API (server-side only)
# Secret API key for the Jooble REST API, used by server-side routes or
# Cloudflare Workers to fetch real job and internship listings.
# Do not expose this value to the client.
# ---------------------------------------------------------------------------
JOOBLE_API_KEY=

# ---------------------------------------------------------------------------
# Cloudflare Turnstile (frontend)
# Public site key for the Turnstile widget, used on sign-up and
# forgot-password pages. The secret key stays on the backend/Workers only.
# Leave empty to use the in-code test key so the widget appears; set to your
# key from the Cloudflare dashboard when ready for production.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
